{
  "kind": "collectionType",
  "collectionName": "lead_submissions",
  "info": {
    "singularName": "lead-submission",
    "pluralName": "lead-submissions",
    "displayName": "Lead Submissions"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": { "i18n": { "localized": false } },
  "attributes": {
    "type": { "type": "enumeration", "enum": ["booking", "newsletter", "contact"], "required": true },
    "status": { "type": "enumeration", "enum": ["new", "reviewed", "closed"], "default": "new" },
    "fullName": { "type": "string" },
    "email": { "type": "email", "required": true },
    "phone": { "type": "string" },
    "message": { "type": "text" },
    "sourceUrl": { "type": "string" },
    "payload": { "type": "json" },
    "consent": { "type": "boolean", "default": false },
    "program": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::program.program"
    }
  }
}

