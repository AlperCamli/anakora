{
  "kind": "collectionType",
  "collectionName": "journal_posts",
  "info": {
    "singularName": "journal-post",
    "pluralName": "journal-posts",
    "displayName": "Journal Posts"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "excerpt": { "type": "text", "required": true },
    "content": { "type": "richtext", "required": true },
    "authorName": { "type": "string", "required": true },
    "publishedDate": { "type": "date", "required": true },
    "readTimeMinutes": { "type": "integer", "required": true },
    "featured": { "type": "boolean", "default": false },
    "featuredImage": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "seo": { "type": "component", "component": "common.seo", "repeatable": false },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category"
    }
  }
}

