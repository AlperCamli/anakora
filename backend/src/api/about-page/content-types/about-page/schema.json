{
  "kind": "singleType",
  "collectionName": "about_pages",
  "info": {
    "singularName": "about-page",
    "pluralName": "about-pages",
    "displayName": "About Page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "hero": { "type": "component", "component": "blocks.hero-section", "repeatable": false },
    "storyHeader": { "type": "component", "component": "blocks.section-header", "repeatable": false },
    "storyBody": { "type": "richtext" },
    "storyImage": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "valuesHeader": { "type": "component", "component": "blocks.section-header", "repeatable": false },
    "values": { "type": "component", "component": "common.value-card", "repeatable": true },
    "founderEyebrow": { "type": "string" },
    "founderName": { "type": "string" },
    "founderBody": { "type": "richtext" },
    "founderImage": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "philosophyHeader": { "type": "component", "component": "blocks.section-header", "repeatable": false },
    "philosophyBody": { "type": "richtext" },
    "cta": { "type": "component", "component": "common.cta-block", "repeatable": false }
  }
}

