# Public browser-safe values (exposed to the client bundle by Vite)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_ENABLE_CAPTCHA=false

# Server-only values (never expose in client code)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Optional storage bucket names for content workflows
SUPABASE_STORAGE_BUCKET_PUBLIC=public-assets
SUPABASE_STORAGE_BUCKET_PRIVATE=admin-uploads
